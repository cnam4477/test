local function checkSymbols(symbolType, targetPositions)
    local symbolsPath
    if symbolType == "Angel" then symbolsPath = workspace.World.Puzzles.SymbolPositions.Angels
    elseif symbolType == "Demon" then symbolsPath = workspace.World.Puzzles.SymbolPositions.Demons end
    if not symbolsPath then return "", {} end
    local symbolsToCheck = {}
    for _, child in pairs(symbolsPath:GetChildren()) do
        if child:IsA("BasePart") or child:IsA("Model") then table.insert(symbolsToCheck, child) end
    end
    for _, sName in pairs({"Symbol1","Symbol2","Symbol3","Symbol4","Symbol8"}) do
        local s = symbolsPath:FindFirstChild(sName)
        if s then
            local found = false
            for _, e in pairs(symbolsToCheck) do if e == s then found = true break end end
            if not found then table.insert(symbolsToCheck, s) end
        end
    end
    local validSymbols = {}
    for _, symbol in pairs(symbolsToCheck) do
        if symbol then
            local symbolPosition = getObjectPosition(symbol)
            if symbolPosition then
                local positionIndex = getPositionIndex(symbolPosition, targetPositions)
                local isVisible = hasZeroTransparency(symbol)
                local meshId = getMeshId(symbol)
                local mappedValue = meshId and meshIdMapping[meshId]
                if positionIndex and isVisible and mappedValue then
                    table.insert(validSymbols, { positionIndex = positionIndex, meshId = meshId, value = mappedValue })
                end
            end
        end
    end
    if #validSymbols > 0 then
        table.sort(validSymbols, function(a, b) return a.positionIndex < b.positionIndex end)
        local result = ""
        for _, sd in pairs(validSymbols) do result = result .. sd.value end
        return result, validSymbols
    end
    return "", {}
end

