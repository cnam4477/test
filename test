local function walkTo(targetPos, arrivalDist, timeout)
    arrivalDist = arrivalDist or 5
    timeout = timeout or 60
    local start = tick()
    while tick() - start < timeout do
        local char = player.Character
        if not char then task.wait(0.1) continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if not root or not hum then task.wait(0.1) continue end
        if (root.Position - targetPos).Magnitude <= arrivalDist then break end
        hum:MoveTo(targetPos)
        task.wait(0.1)
    end
end

local function getObjectPosition(object)
    if not object then return nil end
    if object:IsA("BasePart") then return object.Position end
    if object:IsA("Model") then
        if object.PrimaryPart then return object.PrimaryPart.Position end
        local ok, cf = pcall(function() return object:GetBoundingBox() end)
        if ok and cf then return cf.Position end
        for _, c in pairs(object:GetDescendants()) do
            if c:IsA("BasePart") then return c.Position end
        end
    end
    return nil
end

local function getObjectPos(obj) return getObjectPosition(obj) end

