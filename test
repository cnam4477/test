        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if not root or not hum then task.wait(0.15) continue end
        local d = workspace:FindFirstChild("SkeletalDragon", true)
        if d then
            walkAttacking = false
            humanoid.WalkSpeed = 16
            return d
        end
        if (root.Position - bossTargetPos).Magnitude <= 8 then break end
        hum:MoveTo(bossTargetPos)
        task.wait(0.15)
    end
    walkAttacking = false
    humanoid.WalkSpeed = 16
    return nil
end

local function findDragonWithRetry()
    local d = workspace:FindFirstChild("SkeletalDragon", true)
    if d then return d end
    local waitStart = tick()
    while tick() - waitStart < 8 do
        task.wait(0.5)
        d = workspace:FindFirstChild("SkeletalDragon", true)
        if d then return d end
    end
    return nil
end

