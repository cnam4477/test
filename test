local function comparePosition(pos1, pos2, tolerance)
    return (pos1 - pos2).Magnitude <= (tolerance or 0.1)
end

local function getPositionIndex(symbolPosition, targetPositions)
    for i, targetPos in pairs(targetPositions) do
        if comparePosition(symbolPosition, targetPos) then return i end
    end
    return nil
end

local function hasZeroTransparency(symbol)
    if symbol.Transparency ~= nil and symbol.Transparency == 0 then return true end
    for _, child in pairs(symbol:GetChildren()) do
        if (child:IsA("BasePart") or child:IsA("MeshPart")) and child.Transparency == 0 then return true end
    end
    return false
end

local function getMeshId(symbol)
    if symbol:IsA("MeshPart") and symbol.MeshId ~= "" then return symbol.MeshId end
    local sm = symbol:FindFirstChildOfClass("SpecialMesh")
    if sm and sm.MeshId ~= "" then return sm.MeshId end
    for _, child in pairs(symbol:GetChildren()) do
        if child:IsA("MeshPart") and child.MeshId ~= "" then return child.MeshId end
        local csm = child:FindFirstChildOfClass("SpecialMesh")
        if csm and csm.MeshId ~= "" then return csm.MeshId end
    end
    return nil
end

